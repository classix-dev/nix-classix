+/* The wordmark is a flex item of `.element.logo` (column flex,
+   align-items: flex-start). Block children inside that container
+   collapse to 0×0 due to MUI's CssBaseline cascade. We:
+   - `align-self: stretch` to fill the slot's horizontal cross-axis
+   - make the wordmark itself a flex column so vertical sizing is
+     governed by `min-height: max-content` on the children
+   - set explicit pixel heights on each line so text always paints */
+.catacombWordmark {
+  display: flex;
+  flex-direction: column;
+  justify-content: center;
+  align-items: stretch;
+  align-self: stretch;
+  gap: 2px;
+  text-decoration: none;
+  padding: 0;
+}
+
+.catacombName,
+.catacombEdition {
+  display: block;
+  white-space: nowrap;
+  margin: 0;
+  padding: 0;
+  flex: 0 0 auto;
+  width: auto;
+  min-width: max-content;
+  min-height: max-content;
+}
+
+.catacombName {
+  font-family: 'Space Grotesk', system-ui, sans-serif;
+  font-weight: 600;
+  font-size: 16px;
+  line-height: 18px;
+  height: 18px;
+  letter-spacing: -0.005em;
+  color: var(--color-text-primary);
+}
+
+.catacombEdition {
+  font-family: 'Michroma', system-ui, sans-serif;
+  font-weight: 400;
+  font-size: 12px;
+  line-height: 14px;
+  height: 14px;
+  letter-spacing: 0.12em;
+  text-transform: lowercase;
+  color: #12ff80;
+}
+
+@media (max-width: 899.95px) {
+  .catacombName {
+    font-size: 14px;
+    line-height: 16px;
+    height: 16px;
+  }
+  .catacombEdition {
+    font-size: 11px;
+    line-height: 13px;
+    height: 13px;
+  }
+}
+
 .logo {
   padding: var(--space-1) var(--space-2);
 }
