+  // Catacomb notification: full-screen modal that re-fires every
+  // CATACOMB_NOTIFICATION_INTERVAL_MS. localStorage holds the last ack
+  // timestamp; we re-evaluate on mount and on a 1-min poll so a user
+  // who never reloads still sees the modal again on schedule.
+  const [catacombNotificationOpen, setCatacombNotificationOpen] = useState(false)
+  useEffect(() => {
+    if (!CATACOMB_NOTIFICATION) return
+    if (typeof window === 'undefined') return
+    const evaluate = () => {
+      let lastAck = 0
+      try {
+        const raw = window.localStorage.getItem(CATACOMB_NOTIFICATION_ACK_KEY)
+        const parsed = raw ? Number(raw) : 0
+        lastAck = Number.isFinite(parsed) && parsed > 0 ? parsed : 0
+      } catch {
+        // localStorage may throw in private mode / disabled — treat as never acked
+      }
+      if (Date.now() - lastAck >= CATACOMB_NOTIFICATION_INTERVAL_MS) {
+        setCatacombNotificationOpen(true)
+      }
+    }
+    evaluate()
+    const id = window.setInterval(evaluate, CATACOMB_NOTIFICATION_POLL_MS)
+    return () => window.clearInterval(id)
+  }, [])
+  const handleCatacombNotificationAck = () => {
+    setCatacombNotificationOpen(false)
+    try {
+      window.localStorage.setItem(CATACOMB_NOTIFICATION_ACK_KEY, String(Date.now()))
+    } catch {
+      // ignore — ack not persisted, but the user has seen it this load
+    }
+  }
+
